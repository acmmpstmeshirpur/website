<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ACM MPSTME Shirpur</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=VT323&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --gold: #f5a623;
    --gold-dim: #b87415;
    --gold-glow: #ffcc55;
    --bg: #030303;
    --scanline-opacity: 0.18;
  }

  html, body {
    width: 100%; height: 100%;
    overflow: hidden;
    background: var(--bg);
    font-family: 'Share Tech Mono', monospace;
    cursor: none;
  }

  /* ── Custom cursor ── */
  #cursor {
    position: fixed; width: 18px; height: 18px;
    border: 2px solid var(--gold);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%,-50%);
    transition: width .15s, height .15s, opacity .2s;
    mix-blend-mode: screen;
  }
  #cursor::after {
    content:''; position:absolute; top:50%; left:50%;
    transform:translate(-50%,-50%);
    width:4px; height:4px;
    background: var(--gold-glow);
    border-radius:50%;
    box-shadow: 0 0 6px var(--gold-glow);
  }

  /* ── CRT WRAPPER ── */
  #crt {
    position: fixed; inset: 0;
    overflow: hidden;
    transform-origin: center center;
  }

  /* Scanlines overlay */
  #crt::before {
    content: '';
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,var(--scanline-opacity)) 2px,
      rgba(0,0,0,var(--scanline-opacity)) 4px
    );
    pointer-events: none;
    z-index: 100;
    animation: scanroll 8s linear infinite;
  }

  /* Vignette */
  #crt::after {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at center,
      transparent 55%,
      rgba(0,0,0,0.55) 80%,
      rgba(0,0,0,0.88) 100%
    );
    pointer-events: none;
    z-index: 101;
  }

  @keyframes scanroll {
    0%   { background-position: 0 0; }
    100% { background-position: 0 -200px; }
  }

  /* RGB shift noise flicker */
  @keyframes crtflicker {
    0%,100%  { opacity: 1; }
    96%      { opacity: 1; }
    96.5%    { opacity: 0.92; }
    97%      { opacity: 1; }
    99%      { opacity: 0.97; }
    99.5%    { opacity: 1; }
  }

  /* ── PAGE SYSTEM ── */
  .page {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    transition: opacity .05s;
  }

  /* ── PAGE 1 – LOGO ── */
  #page-logo {
    background: var(--bg);
    animation: crtflicker 9s infinite;
  }

  .logo-wrap {
    position: relative;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 0;
  }

  /* The SVG logo recreation */
  .logo-svg-wrap {
    position: relative;
    width: 360px; height: 400px;
    display: flex; align-items: center; justify-content: center;
  }

  /* outer frame bracket */
  .frame-svg {
    position: absolute; inset: 0;
    animation: pulseglow 3s ease-in-out infinite;
  }

  @keyframes pulseglow {
    0%,100% { filter: drop-shadow(0 0 6px var(--gold)) drop-shadow(0 0 18px var(--gold-dim)); }
    50%     { filter: drop-shadow(0 0 14px var(--gold-glow)) drop-shadow(0 0 40px var(--gold)); }
  }

  .logo-text-block {
    text-align: center;
    margin-top: -10px;
    animation: pulseglow 3s ease-in-out infinite;
  }

  .logo-mpstme {
    font-family: 'Orbitron', monospace;
    font-weight: 900;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    letter-spacing: 0.25em;
    color: var(--gold-glow);
    text-shadow:
      0 0 8px var(--gold),
      0 0 24px var(--gold-dim),
      0 0 48px rgba(245,166,35,0.3);
    line-height: 1;
  }

  .logo-shirpur {
    font-family: 'Orbitron', monospace;
    font-weight: 700;
    font-size: clamp(1.4rem, 3vw, 2rem);
    letter-spacing: 0.55em;
    color: var(--gold);
    text-shadow:
      0 0 6px var(--gold),
      0 0 18px var(--gold-dim);
    margin-top: 0.15em;
  }

  /* scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 48px;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'VT323', monospace;
    font-size: 1.3rem;
    color: var(--gold-dim);
    letter-spacing: 0.2em;
    opacity: 0;
    animation: fadehint 1s ease-out 2.5s forwards, blinkhint 1.2s ease-in-out 3.5s infinite;
    z-index: 10;
  }

  @keyframes fadehint {
    to { opacity: 0.7; }
  }
  @keyframes blinkhint {
    0%,100% { opacity: 0.7; }
    50%      { opacity: 0.2; }
  }

  .scroll-hint::after {
    content: ' ▼';
    animation: bounce 1.5s ease-in-out 3.5s infinite;
    display: inline-block;
  }

  @keyframes bounce {
    0%,100% { transform: translateY(0); }
    50%     { transform: translateY(5px); }
  }

  /* ── CRT TRANSITION ── */
  /* Step 1: horizontal compression (the squish-to-line) */
  @keyframes crtOut_squish {
    0%   { transform: scaleY(1); filter: brightness(1); }
    40%  { transform: scaleY(0.06) scaleX(1.04); filter: brightness(2.5) saturate(0.2); }
    60%  { transform: scaleY(0.01) scaleX(1.08); filter: brightness(6); }
    80%  { transform: scaleY(0) scaleX(1.1);  filter: brightness(10); opacity: 0; }
    100% { transform: scaleY(0) scaleX(0);    opacity: 0; }
  }

  @keyframes crtIn_expand {
    0%   { transform: scaleY(0) scaleX(0); opacity: 0; filter: brightness(10); }
    20%  { transform: scaleY(0) scaleX(1.1); opacity: 1; filter: brightness(8); }
    40%  { transform: scaleY(0.02) scaleX(1.08); filter: brightness(5); }
    65%  { transform: scaleY(0.08) scaleX(1.04); filter: brightness(2); }
    85%  { transform: scaleY(1.02) scaleX(1.01); filter: brightness(1.2); }
    100% { transform: scaleY(1) scaleX(1); filter: brightness(1); }
  }

  #crt.transition-out {
    animation: crtOut_squish 0.55s cubic-bezier(.4,0,.6,1) forwards;
    pointer-events: none;
  }

  #crt.transition-in {
    animation: crtIn_expand 0.7s cubic-bezier(.2,0,.3,1) forwards;
  }

  /* static noise flash */
  #static {
    position: fixed; inset: 0;
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    mix-blend-mode: screen;
  }

  #static.flash {
    animation: staticflash 0.55s steps(1) forwards;
  }

  @keyframes staticflash {
    0%   { opacity: 0; }
    10%  { opacity: 0.55; }
    25%  { opacity: 0.2; }
    40%  { opacity: 0.7; }
    55%  { opacity: 0.1; }
    70%  { opacity: 0.4; }
    85%  { opacity: 0; }
    100% { opacity: 0; }
  }

  /* scan-line wipe for entering page */
  #scanwipe {
    position: fixed; inset: 0; z-index: 150;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(245,166,35,0.08) 48%,
      rgba(245,166,35,0.22) 50%,
      rgba(245,166,35,0.08) 52%,
      transparent 100%
    );
    background-size: 100% 400%;
    opacity: 0;
  }

  #scanwipe.wipe {
    animation: scanwipe 0.7s ease-out forwards;
  }

  @keyframes scanwipe {
    0%   { opacity: 1; background-position: 0 -100%; }
    100% { opacity: 0; background-position: 0 200%; }
  }

  /* ── PAGE 2 – LANDING ── */
  #page-landing {
    background: var(--bg);
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    animation: crtflicker 12s infinite;
    overflow: hidden;
  }

  /* grid overlay for landing */
  #page-landing::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(245,166,35,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(245,166,35,0.04) 1px, transparent 1px);
    background-size: 44px 44px;
    pointer-events: none;
  }

  .landing-header {
    display: flex; flex-direction: column;
    align-items: center;
    gap: 0.3em;
    margin-bottom: 3.5rem;
    position: relative;
  }

  .landing-badge {
    font-family: 'VT323', monospace;
    font-size: 1.1rem;
    letter-spacing: 0.4em;
    color: var(--gold-dim);
    text-transform: uppercase;
    opacity: 0;
    animation: fadeup 0.6s ease-out 0.3s forwards;
  }

  .landing-title {
    font-family: 'Orbitron', monospace;
    font-weight: 900;
    font-size: clamp(2rem, 5vw, 3.8rem);
    color: var(--gold-glow);
    letter-spacing: 0.12em;
    text-shadow: 0 0 12px var(--gold), 0 0 36px rgba(245,166,35,0.4);
    opacity: 0;
    animation: fadeup 0.6s ease-out 0.5s forwards;
    line-height: 1.1;
    text-align: center;
  }

  .landing-sub {
    font-family: 'Share Tech Mono', monospace;
    font-size: clamp(0.75rem, 1.5vw, 0.95rem);
    color: var(--gold-dim);
    letter-spacing: 0.25em;
    opacity: 0;
    animation: fadeup 0.6s ease-out 0.7s forwards;
    margin-top: 0.4em;
  }

  /* horizontal rule */
  .hr-gold {
    width: min(520px, 80vw);
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: fadeup 0.6s ease-out 0.85s forwards;
    box-shadow: 0 0 8px var(--gold-dim);
  }

  /* nav cards */
  .nav-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
    width: min(700px, 90vw);
    opacity: 0;
    animation: fadeup 0.7s ease-out 1s forwards;
  }

  .nav-card {
    border: 1px solid var(--gold-dim);
    padding: 1.3rem 1rem;
    text-align: center;
    position: relative;
    cursor: none;
    overflow: hidden;
    transition: border-color 0.2s, background 0.2s;
    background: rgba(245,166,35,0.03);
  }

  .nav-card::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(245,166,35,0.08) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.25s;
  }

  .nav-card:hover {
    border-color: var(--gold-glow);
    background: rgba(245,166,35,0.07);
  }

  .nav-card:hover::before { opacity: 1; }

  .nav-card:hover .card-icon {
    text-shadow: 0 0 16px var(--gold-glow);
    transform: scale(1.15);
  }

  .card-icon {
    font-size: 1.8rem;
    display: block;
    margin-bottom: 0.5rem;
    transition: transform 0.2s, text-shadow 0.2s;
    color: var(--gold);
    text-shadow: 0 0 8px var(--gold-dim);
  }

  .card-label {
    font-family: 'Orbitron', monospace;
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: var(--gold);
    text-transform: uppercase;
  }

  .card-desc {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    color: var(--gold-dim);
    margin-top: 0.3em;
    letter-spacing: 0.05em;
  }

  /* corner decorations */
  .corner {
    position: absolute;
    width: 24px; height: 24px;
    border-color: var(--gold-dim);
    border-style: solid;
    opacity: 0.6;
  }
  .corner.tl { top: 16px; left: 16px; border-width: 2px 0 0 2px; }
  .corner.tr { top: 16px; right: 16px; border-width: 2px 2px 0 0; }
  .corner.bl { bottom: 16px; left: 16px; border-width: 0 0 2px 2px; }
  .corner.br { bottom: 16px; right: 16px; border-width: 0 2px 2px 0; }

  /* status bar */
  .status-bar {
    position: absolute;
    bottom: 20px;
    left: 50%; transform: translateX(-50%);
    display: flex; gap: 2rem; align-items: center;
    opacity: 0;
    animation: fadeup 0.5s ease-out 1.3s forwards;
  }

  .status-item {
    font-family: 'VT323', monospace;
    font-size: 1rem;
    color: var(--gold-dim);
    letter-spacing: 0.15em;
  }

  .status-dot {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--gold);
    margin-right: 6px;
    box-shadow: 0 0 6px var(--gold);
    animation: blinkhint 1.8s ease-in-out infinite;
  }

  @keyframes fadeup {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── intro boot sequence ── */
  #boot-overlay {
    position: fixed; inset: 0;
    z-index: 300;
    background: var(--bg);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    pointer-events: none;
    animation: bootfade 0.4s ease-out 1.8s forwards;
  }

  @keyframes bootfade {
    to { opacity: 0; visibility: hidden; }
  }

  .boot-line {
    font-family: 'VT323', monospace;
    font-size: 1.1rem;
    color: var(--gold-dim);
    letter-spacing: 0.25em;
    opacity: 0;
    white-space: nowrap;
  }

  .boot-line:nth-child(1) { animation: bootappear 0.1s 0.1s forwards; }
  .boot-line:nth-child(2) { animation: bootappear 0.1s 0.4s forwards; }
  .boot-line:nth-child(3) { animation: bootappear 0.1s 0.7s forwards; }
  .boot-line:nth-child(4) { animation: bootappear 0.1s 1.0s forwards; color: var(--gold); }

  @keyframes bootappear { to { opacity: 1; } }

  /* back button on page 2 */
  .back-btn {
    position: absolute;
    top: 22px; left: 22px;
    font-family: 'VT323', monospace;
    font-size: 1.2rem;
    color: var(--gold-dim);
    letter-spacing: 0.2em;
    cursor: none;
    opacity: 0;
    animation: fadeup 0.4s ease-out 1.5s forwards;
    transition: color 0.15s;
    user-select: none;
  }

  .back-btn:hover { color: var(--gold-glow); text-shadow: 0 0 8px var(--gold); }

  /* small ACM logo top-right on landing */
  .mini-logo {
    position: absolute;
    top: 16px; right: 22px;
    font-family: 'Orbitron', monospace;
    font-weight: 900;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--gold-dim);
    opacity: 0;
    animation: fadeup 0.4s ease-out 1.5s forwards;
  }
</style>
</head>
<body>

<!-- Custom cursor -->
<div id="cursor"></div>

<!-- Boot sequence -->
<div id="boot-overlay">
  <div class="boot-line">ACM_MPSTME_SHIRPUR // SYSTEM_INIT</div>
  <div class="boot-line">LOADING KERNEL... OK</div>
  <div class="boot-line">DISPLAY DRIVER READY</div>
  <div class="boot-line">▌ WELCOME ▐</div>
</div>

<!-- Static noise flash layer -->
<div id="static"></div>
<!-- Scan wipe layer -->
<div id="scanwipe"></div>

<!-- CRT wrapper -->
<div id="crt">

  <!-- PAGE 1: Logo -->
  <div class="page" id="page-logo">
    <div class="logo-wrap">

      <div class="logo-svg-wrap">
        <svg class="frame-svg" viewBox="0 0 320 400" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <filter id="glow" x="-40%" y="-40%" width="180%" height="180%">
              <feGaussianBlur stdDeviation="4" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <filter id="glow2" x="-25%" y="-25%" width="150%" height="150%">
              <feGaussianBlur stdDeviation="2.5" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <filter id="textglow" x="-20%" y="-40%" width="140%" height="180%">
              <feGaussianBlur stdDeviation="3" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>

          <!-- ── ACM DIAMOND: outer border, center 160,145, arm=130 ── -->
          <polygon points="160,15 290,145 160,275 30,145"
            fill="none"
            stroke="#f5a623" stroke-width="3.5"
            stroke-linejoin="miter"
            filter="url(#glow)"/>

          <!-- ── ACM DIAMOND: inner border (~16px inward) ── -->
          <polygon points="160,31 274,145 160,259 46,145"
            fill="none"
            stroke="#f5a623" stroke-width="2"
            stroke-linejoin="miter"
            opacity="0.65"
            filter="url(#glow)"/>

          <!-- ── acm text: centered at diamond centroid 160,145 ── -->
          <foreignObject x="60" y="100" width="200" height="90">
            <div xmlns="http://www.w3.org/1999/xhtml" style="width:200px;height:90px;display:flex;align-items:center;justify-content:center;">
              <span style="font-family:'Arial Black',Arial,sans-serif;font-weight:900;font-size:58px;color:#ffdd77;text-shadow:0 0 12px #f5a623,0 0 28px rgba(245,166,35,0.5);line-height:1;user-select:none;">acm</span>
            </div>
          </foreignObject>

          <!-- divider line -->
          <line x1="50" y1="292" x2="270" y2="292" stroke="#f5a623" stroke-width="0.8" opacity="0.35"/>

          <!-- ── MPSTME ── -->
          <text x="160" y="322"
            text-anchor="middle"
            font-family="Orbitron, monospace"
            font-weight="900"
            font-size="42"
            letter-spacing="8"
            fill="#f5a623"
            filter="url(#glow2)">MPSTME</text>

          <!-- ── SHIRPUR ── -->
          <text x="160" y="360"
            text-anchor="middle"
            font-family="Orbitron, monospace"
            font-weight="700"
            font-size="28"
            letter-spacing="12"
            fill="#c8860f">SHIRPUR</text>

          <!-- ── Student Chapter ── -->
          <text x="160" y="384"
            text-anchor="middle"
            font-family="Share Tech Mono, monospace"
            font-size="13"
            letter-spacing="5"
            fill="#8a5c08"
            opacity="0.9">STUDENT CHAPTER</text>
        </svg>
      </div>
    </div>

    <div class="scroll-hint">PRESS ANY KEY TO ENTER</div>
  </div>

  <!-- PAGE 2: Landing -->
  <div class="page" id="page-landing">
    <!-- Corner decorations -->
    <div class="corner tl"></div>
    <div class="corner tr"></div>
    <div class="corner bl"></div>
    <div class="corner br"></div>

    <div class="back-btn" id="backBtn">◄ BACK</div>
    <div class="mini-logo">ACM // MPSTME</div>

    <div class="landing-header">
      <div class="landing-badge">// Student Chapter //</div>
      <div class="landing-title">ACM MPSTME<br>SHIRPUR</div>
      <div class="landing-sub">NMIMS UNIVERSITY · SHIRPUR · MAHARASHTRA</div>
    </div>

    <div class="hr-gold"></div>

    <div class="nav-grid">
      <div class="nav-card">
        <span class="card-icon">◈</span>
        <div class="card-label">About</div>
        <div class="card-desc">Who we are & our mission</div>
      </div>
      <div class="nav-card">
        <span class="card-icon">⬡</span>
        <div class="card-label">Events</div>
        <div class="card-desc">Workshops, talks & hackathons</div>
      </div>
      <div class="nav-card">
        <span class="card-icon">△</span>
        <div class="card-label">Projects</div>
        <div class="card-desc">Research & open-source work</div>
      </div>
      <div class="nav-card">
        <span class="card-icon">⊕</span>
        <div class="card-label">Team</div>
        <div class="card-desc">Members & leadership</div>
      </div>
      <div class="nav-card">
        <span class="card-icon">◻</span>
        <div class="card-label">Resources</div>
        <div class="card-desc">Learning materials & repos</div>
      </div>
      <div class="nav-card">
        <span class="card-icon">◉</span>
        <div class="card-label">Join Us</div>
        <div class="card-desc">Become a member today</div>
      </div>
    </div>

    <div class="status-bar">
      <div class="status-item"><span class="status-dot"></span>SYSTEM ONLINE</div>
      <div class="status-item">SY 2025–26</div>
      <div class="status-item">ACM // IEEE</div>
    </div>
  </div>

</div><!-- /crt -->

<script>
  // ── Cursor
  const cursor = document.getElementById('cursor');
  document.addEventListener('mousemove', e => {
    cursor.style.left = e.clientX + 'px';
    cursor.style.top  = e.clientY + 'px';
  });

  // ── State
  let currentPage = 1;
  let transitioning = false;

  const crt = document.getElementById('crt');
  const pageLogo = document.getElementById('page-logo');
  const pageLanding = document.getElementById('page-landing');
  const staticEl = document.getElementById('static');
  const scanwipe = document.getElementById('scanwipe');
  const backBtn = document.getElementById('backBtn');

  function doTransition(toPage) {
    if (transitioning) return;
    transitioning = true;

    // 1. CRT squish out
    crt.classList.add('transition-out');

    setTimeout(() => {
      // 2. Static flash
      staticEl.classList.add('flash');

      // 3. Switch pages
      if (toPage === 2) {
        pageLogo.style.display = 'none';
        pageLanding.style.display = 'flex';
        currentPage = 2;
      } else {
        pageLanding.style.display = 'none';
        pageLogo.style.display = 'flex';
        currentPage = 1;
      }

      // 4. CRT expand in
      crt.classList.remove('transition-out');
      crt.classList.add('transition-in');

      // 5. Scan wipe
      setTimeout(() => {
        scanwipe.classList.add('wipe');
      }, 80);

      setTimeout(() => {
        crt.classList.remove('transition-in');
        staticEl.classList.remove('flash');
        scanwipe.classList.remove('wipe');
        transitioning = false;
      }, 750);

    }, 530);
  }

  // Trigger on any key, click, or scroll on page 1
  function handleEnter() {
    if (currentPage === 1) doTransition(2);
  }

  document.addEventListener('keydown', handleEnter);
  document.addEventListener('click', handleEnter);
  document.addEventListener('wheel', (e) => {
    if (currentPage === 1 && e.deltaY > 0) handleEnter();
  });

  // Touch swipe
  let touchStartY = 0;
  document.addEventListener('touchstart', e => { touchStartY = e.touches[0].clientY; });
  document.addEventListener('touchend', e => {
    if (currentPage === 1 && touchStartY - e.changedTouches[0].clientY > 40) handleEnter();
    if (currentPage === 2 && e.changedTouches[0].clientY - touchStartY > 40) doTransition(1);
  });

  backBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    if (currentPage === 2) doTransition(1);
  });

  // Cursor expand on hover nav-cards
  document.querySelectorAll('.nav-card, .back-btn').forEach(el => {
    el.addEventListener('mouseenter', () => {
      cursor.style.width = '30px';
      cursor.style.height = '30px';
    });
    el.addEventListener('mouseleave', () => {
      cursor.style.width = '18px';
      cursor.style.height = '18px';
    });
  });

  // Random CRT glitch
  setInterval(() => {
    if (Math.random() < 0.06 && !transitioning) {
      crt.style.transform = `translate(${(Math.random()-0.5)*2}px, ${(Math.random()-0.5)*0.8}px)`;
      setTimeout(() => { crt.style.transform = ''; }, 50);
    }
  }, 3500);
</script>
</body>
</html>
